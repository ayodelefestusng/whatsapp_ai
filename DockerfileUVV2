# Stage 1: Build
FROM python:3.11-slim AS builder

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

# Copy requirements
COPY requirements.txt .

# CRITICAL: Use --system so packages go to /usr/local/lib/python3.11/site-packages
# This allows Stage 2 to find them easily.
RUN uv pip install --system --no-cache -r requirements.txt

# Stage 2: Runtime
FROM python:3.11-slim

WORKDIR /app

# Copy the installed packages from the builder stage
# We use the standard Python path
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy your source code
COPY . .

# Ensure the app doesn't buffer logs (useful for Easypanel/Digital Ocean monitoring)
ENV PYTHONUNBUFFERED=1

CMD ["python", "main.py"]